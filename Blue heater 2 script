local function Notify(title, content, duration)
    duration = duration or 3
    pcall(function()
        Fluent:Notify({
            Title = title,
            Content = content,
            Duration = duration
        })
    end)
end

local function IsBoss(name)
    if not name then return false end
    local lower = name:lower()
    for _, bossName in ipairs(DungeonSystem.DungeonBosses) do
        if lower:find(bossName:lower()) then
            return true
        end
    end
    return lower:find("boss") ~= nil or lower:find("king") ~= nil or lower:find("master") ~= nil
end

local function IsDungeonMob(name)
    if not name then return false end
    local lower = name:lower()
    
    -- Check against known dungeon mobs
    for _, mobName in ipairs(DungeonSystem.DungeonMobs) do
        if lower:find(mobName:lower()) then
            return true
        end
    end
    
    -- Check for dungeon-related keywords
    return lower:find("skeleton") or lower:find("bandit") or lower:find("goblin") or 
           lower:find("wolf") or lower:find("slime") or lower:find("dungeon") or 
           lower:find("guardian") or lower:find("zombie") or lower:find("ghoul") or
           lower:find("wraith") or lower:find("specter") or lower:find("spider") or
           lower:find("vampire") or lower:find("keeper") or lower:find("pyunnit") or
           lower:find("dunescourge") or lower:find("cyclops") or lower:find("minotaur")
end

local function IsLoot(name)
    if not name then return false end
    local lower = name:lower()
    for _, keyword in ipairs(DungeonSystem.LootKeywords) do
        if lower:find(keyword) then
            return true
        end
    end
    return false
end

local function FireHit(targets)
    if Remotes.MultiEntityHit and #targets > 0 then
        pcall(function()
            Remotes.MultiEntityHit:FireServer(targets)
        end)
    end
end

local function SafeTeleport(cframe)
    if not State.RootPart then return false end
    local success = pcall(function()
        State.RootPart.Anchored = true
        State.RootPart.CFrame = cframe
        State.RootPart.AssemblyLinearVelocity = V3_ZERO
        task.wait(0.08)
        if State.RootPart then
            State.RootPart.Anchored = false
        end
    end)
    return success
end

local function FarmTeleport(cframe)
    if not State.RootPart or not State.RootPart.Parent then return false end
    if State.IsFarmTeleporting then return false end
    
    State.IsFarmTeleporting = true
    
    local success = pcall(function()
        State.RootPart.AssemblyLinearVelocity = V3_ZERO
        State.RootPart.RotVelocity = V3_ZERO
        State.RootPart.Anchored = true
        State.RootPart.CFrame = cframe
        State.RootPart.AssemblyLinearVelocity = V3_ZERO
        State.RootPart.RotVelocity = V3_ZERO
        RunService.Stepped:Wait()
        if State.RootPart then
            State.RootPart.Anchored = false
        end
    end)
    
    State.IsFarmTeleporting = false
    return success
end

