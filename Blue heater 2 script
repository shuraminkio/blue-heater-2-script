        NoclipSystem.Connection:Disconnect()
        NoclipSystem.Connection = nil
    end
    if NoclipSystem.DescendantConnection then
        NoclipSystem.DescendantConnection:Disconnect()
        NoclipSystem.DescendantConnection = nil
    end
    
    for _, part in ipairs(NoclipSystem.Parts) do
