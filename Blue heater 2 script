-- ═══════════════════════════════════════════════════════════════════════════════
--   CORE LOOPS
-- ═══════════════════════════════════════════════════════════════════════════════

local function InitializeCoreLoops()
    -- Physics Loop
    RunService.Heartbeat:Connect(function()
        if not State.Humanoid or not State.RootPart or not State.Humanoid.Parent then
            return
        end
        
        if not State.StartupDone then return end
        
        -- Float System
        if Features.Float.Enabled then
            local velocity = State.RootPart.AssemblyLinearVelocity
            if math.abs(velocity.Y) > 0.5 then
                State.RootPart.AssemblyLinearVelocity = Vector3.new(velocity.X, 0, velocity.Z)
            end
            
            local rotVelocity = State.RootPart.RotVelocity
            if rotVelocity.Magnitude > 0.1 then
                State.RootPart.RotVelocity = V3_ZERO
            end
        end
        
        -- Anti-Fall
        if Features.AntiFall.Enabled then
            State.Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            local velocity = State.RootPart.AssemblyLinearVelocity
            if velocity.Y < -50 then
                State.RootPart.AssemblyLinearVelocity = Vector3.new(velocity.X, -50, velocity.Z)
            end
        end
    end)
    
    -- Player Polling Loop
    LoopManager.Start("PlayerPolling", 0.05, function()
        if not State.Humanoid or not State.Humanoid.Parent then return end
        
        -- Walk Speed
        if Features.WalkSpeed.Enabled and State.Humanoid.WalkSpeed ~= Features.WalkSpeed.Value then
            State.Humanoid.WalkSpeed = Features.WalkSpeed.Value
        end
        
        -- Infinite Stamina
        if Features.InfStamina.Enabled and State.StaminaObj then
            local max = State.StaminaObj:GetAttribute("Max") or 100
            if State.StaminaObj.Value < max then
                State.StaminaObj.Value = max
            end
        end
    end)
    
    -- Dungeon Detection Loop
    LoopManager.Start("DungeonDetection", 2, function()
        UpdateDungeonStatus()
    end)
    
    -- Kill Aura Loop (Enhanced - Multiple Rapid Hits)
    local killAuraTargets = {}
    LoopManager.Start("KillAura", Features.KillAura.Interval, function()
        if not Features.KillAura.Enabled or not State.RootPart or not State.RootPart.Parent then
            return
        end
        
        if not State.Humanoid or State.Humanoid.Health <= 0 then return end
        
        local position = State.RootPart.Position
        local radius = Features.KillAura.Radius
        local count = 0
        
        for _, entity in ipairs(EntityCache.List) do
            if entity and entity ~= State.Character and entity.Parent then
                local root = entity:FindFirstChild("HumanoidRootPart")
                local humanoid = entity:FindFirstChildOfClass("Humanoid")
                
                if root and humanoid and humanoid.Health > 0 and (position - root.Position).Magnitude <= radius then
                    count = count + 1
                    if Features.KillAura.BossPriority and IsBoss(entity.Name) then
                        table.insert(killAuraTargets, 1, entity)
                    else
                        killAuraTargets[count] = entity
                    end
                end
            end
        end
        
        if count > 0 then
            -- Fire multiple rapid hits for better damage
            for hitRound = 1, 3 do
                FireHit(killAuraTargets)
            end
            table.clear(killAuraTargets)
            
            if State.RootPart and State.RootPart.Parent then
                State.RootPart.RotVelocity = V3_ZERO
            end
        end
    end)
    
    -- Instant Kill Loop (One-Shot Kill - Direct Damage)
    LoopManager.Start("InstantKill", 0.06, function()
        if not Features.InstantKill.Enabled or not State.RootPart or not State.RootPart.Parent then
            return
        end
        
        if not State.Humanoid or State.Humanoid.Health <= 0 then return end
        
        local position = State.RootPart.Position
        local radius = Features.KillAura.Radius
        local instantKillTargets = {}
        local targetCount = 0
        
        for _, entity in ipairs(EntityCache.List) do
            if entity and entity ~= State.Character and entity.Parent then
                local humanoid = entity:FindFirstChildOfClass("Humanoid")
                local root = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                
                if root and humanoid and humanoid.Health > 0 and (position - root.Position).Magnitude <= radius then
                    targetCount = targetCount + 1
                    instantKillTargets[targetCount] = entity
                end
            end
        end
        
        -- Fast but stable hits on all targets
        if targetCount > 0 then
            for hitRound = 1, 12 do
                FireHit(instantKillTargets)
            end
        end
    end)
    
    -- Auto Dodge Loop – Instant "dodge to hitbox" style (direct CFrame teleport)
LoopManager.Start("AutoDodge", 0.08, function()
    if not Features.AutoDodge.Enabled or not State.StartupDone then 
        return 
    end
    if not State.Humanoid or not State.RootPart or not State.RootPart.Parent then 
        return 
    end
    
    -- Only trigger when health is low enough
    if State.Humanoid.Health > State.Humanoid.MaxHealth * Features.AutoDodge.Threshold then 
        return 
    end

    local playerPos   = State.RootPart.Position
    local closestRoot = nil
    local closestDist = 17   -- tune: 14–20

    -- Find closest enemy
    for _, entity in ipairs(EntityCache.List) do
        if entity and entity ~= State.Character and entity.Parent then
            local root = entity:FindFirstChild("HumanoidRootPart") 
                      or entity:FindFirstChildWhichIsA("BasePart")
            local hum  = entity:FindFirstChildOfClass("Humanoid")

            if root and hum and hum.Health > 0 then
                local dist = (playerPos - root.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closestRoot = root
                end
            end
        end
    end

    if not closestRoot then 
        return 
    end

    -- Choose left or right side
    local mobRight   = closestRoot.CFrame.RightVector
    local mobForward = closestRoot.CFrame.LookVector

    local toPlayer   = (playerPos - closestRoot.Position).Unit
    local dotRight   = toPlayer:Dot(mobRight)

    local dodgeSide  = (dotRight > 0) and mobRight or -mobRight

    -- Final position: side + slightly behind + up
    local dodgeOffset = dodgeSide * 5.4 
                      + mobForward * -2.2 
                      + Vector3.new(0, 2.8, 0)

    local targetCFrame = closestRoot.CFrame + dodgeOffset

    local lookAt = CFrame.lookAt(targetCFrame.Position, closestRoot.Position)

    -- Instant dodge (with safety pcall)
    pcall(function()
        State.RootPart.CFrame = targetCFrame
        State.RootPart.CFrame = lookAt
        State.RootPart.AssemblyLinearVelocity = Vector3.new(0, 22, 0)  -- small hop
    end)

    task.wait(0.32)   -- anti-spam cooldown
end)
    
    -- Auto Farm Loop
    local farmOffset = CFrame.new(0, 3, 3)
    local farmBuffer = {}
    
    LoopManager.Start("AutoFarm", 0.6, function()
        if not Features.AutoFarm.Enabled or not State.StartupDone then return end
        if not State.RootPart or not State.RootPart.Parent then return end
        if not State.Humanoid or State.Humanoid.Health <= 0 then return end
        
        local position = State.RootPart.Position
        local bestEntity, bestDistance = nil, math.huge
        
        for _, entity in ipairs(EntityCache.List) do
            if entity and entity ~= State.Character and entity.Parent and entity.Name ~= LocalPlayer.Name then
                local root = entity:FindFirstChild("HumanoidRootPart")
                local humanoid = entity:FindFirstChildOfClass("Humanoid")
                
                if root and humanoid and humanoid.Health > 0 then
                    local distance = (position - root.Position).Magnitude
                    
                    if Features.KillAura.BossPriority and IsBoss(entity.Name) then
                        distance = distance - 100000
                    end
                    
                    if distance < bestDistance then
                        bestDistance = distance
                        bestEntity = entity
                    end
                end
            end
        end
        
        if bestEntity then
            local targetRoot = bestEntity:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                if FarmTeleport(targetRoot.CFrame * farmOffset) then
                    farmBuffer[1] = bestEntity
                    FireHit(farmBuffer)
                end
            end
        end
    end)
    
    -- Auto Slime Loop
