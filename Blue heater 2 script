        for _, entity in ipairs(EntityCache.List) do
            if entity and entity ~= State.Character and entity.Parent then
                if entity.Name:lower():find("slime") then
                    local root = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                    local humanoid = entity:FindFirstChildOfClass("Humanoid")
                    local alive = (not humanoid) or (humanoid.Health > 0)
                    
                    if root and root.Parent and alive then
                        if FarmTeleport(root.CFrame * slimeOffset) then
                            buffer[1] = entity
                            FireHit(buffer)
                        end
                        break
                    end
                end
            end
        end
    end)
    
    -- Auto Cryan Ryan Loop
    LoopManager.Start("AutoCryanRyan", 0.6, function()
        if not Features.AutoCryanRyan.Enabled then return end
        
        local offset = CFrame.new(0, 0, -3)
        local buffer = {}
        
        for _, entity in ipairs(EntityCache.List) do
            if entity and entity ~= State.Character and entity.Parent and entity.Name == "Cryan Ryan" then
                local root = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                local humanoid = entity:FindFirstChildOfClass("Humanoid")
                local alive = (not humanoid) or (humanoid.Health > 0)
                
                if root and root.Parent and alive then
                    if FarmTeleport(root.CFrame * offset) then
                        buffer[1] = entity
                        FireHit(buffer)
                    end
                    break
                end
            end
        end
    end)
    
    -- Auto Buff Bee Loop
    LoopManager.Start("AutoBuffBee", 0.6, function()
        if not Features.AutoBuffBee.Enabled then return end
        
        local offset = CFrame.new(0, 0, -3)
        local buffer = {}
        
        for _, entity in ipairs(EntityCache.List) do
            if entity and entity ~= State.Character and entity.Parent and entity.Name == "Buff Bee" then
                local root = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                local humanoid = entity:FindFirstChildOfClass("Humanoid")
                local alive = (not humanoid) or (humanoid.Health > 0)
                
                if root and root.Parent and alive then
                    if FarmTeleport(root.CFrame * offset) then
                        buffer[1] = entity
                        FireHit(buffer)
                    end
                    break
                end
            end
        end
    end)
    
    -- Auto Custom Farm Loop
    LoopManager.Start("AutoCustomFarm", 0.6, function()
        if not Features.AutoModCustom.Enabled then return end
        
        local name = Features.AutoModCustom.Name
        if name == "" or name == "(No mobs found)" or name == "(Click Refresh to load mobs)" then
            return
        end
        
        local offset = CFrame.new(0, 0, -3)
        local buffer = {}
        
        for _, entity in ipairs(EntityCache.List) do
            if entity and entity ~= State.Character and entity.Parent and entity.Name == name then
                local root = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                local humanoid = entity:FindFirstChildOfClass("Humanoid")
                local alive = (not humanoid) or (humanoid.Health > 0)
                
                if root and root.Parent and alive then
                    if FarmTeleport(root.CFrame * offset) then
                        buffer[1] = entity
                        FireHit(buffer)
                    end
                    break
                end
            end
        end
    end)
    
    -- UPDATED: Improved Dungeon Auto Kill Loop
    LoopManager.Start("DungeonAutoKill", 0.3, function()
        if not Features.DungeonAutoKill.Enabled then return end
        if not State.RootPart or not State.RootPart.Parent then return end
        if not State.Humanoid or State.Humanoid.Health <= 0 then return end
        
        local position = State.RootPart.Position
        local buffer = {}
        local foundTarget = false
        
        -- First priority: Bosses if BossOnly mode
        if Features.DungeonBossOnly.Enabled then
            for _, entity in ipairs(EntityCache.List) do
                if entity and entity ~= State.Character and entity.Parent then
                    if IsBoss(entity.Name) and IsDungeonMob(entity.Name) then
                        local root = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                        local humanoid = entity:FindFirstChildOfClass("Humanoid")
                        
                        if root and humanoid and humanoid.Health > 0 then
                            local offset = Features.DungeonSpeedRun.Enabled and CFrame.new(0, 0, -2) or CFrame.new(0, 0, -3)
                            if FarmTeleport(root.CFrame * offset) then
                                buffer[1] = entity
                                FireHit(buffer)
                            end
                            foundTarget = true
                            break
                        end
                    end
                end
            end
        end
        
        -- Second priority: Any dungeon mob
        if not foundTarget then
            for _, entity in ipairs(EntityCache.List) do
                if entity and entity ~= State.Character and entity.Parent then
                    if IsDungeonMob(entity.Name) then
                        local root = entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                        local humanoid = entity:FindFirstChildOfClass("Humanoid")
                        
                        if root and humanoid and humanoid.Health > 0 then
                            if Features.DungeonBossOnly.Enabled and not IsBoss(entity.Name) then
                                continue
                            end
                            
                            local offset = Features.DungeonSpeedRun.Enabled and CFrame.new(0, 0, -2) or CFrame.new(0, 0, -3)
                            if FarmTeleport(root.CFrame * offset) then
                                buffer[1] = entity
                                FireHit(buffer)
                            end
                            break
                        end
                    end
                end
            end
        end
    end)
    
    -- UPDATED: Improved Dungeon Auto Loot Loop
    LoopManager.Start("DungeonAutoLoot", 0.6, function()
        if not Features.DungeonAutoLoot.Enabled then return end
        if not State.RootPart or not State.RootPart.Parent then return end
        
        for _, drop in ipairs(EntityCache.List) do
            if drop and drop.Parent then
                if IsLoot(drop.Name) then
                    local root = drop:FindFirstChild("HumanoidRootPart") or drop:FindFirstChildWhichIsA("BasePart")
                    if root and root.Parent then
                        FarmTeleport(root.CFrame * CFrame.new(0, 0, -2))
                        task.wait(0.1)
                    end
                end
            end
        end
    end)
    
    -- UPDATED: Improved Dungeon Auto Leave Loop
    LoopManager.Start("DungeonAutoLeave", 5, function()
        if not Features.DungeonAutoLeave.Enabled then return end
        if not State.InDungeon then return end
        
        local elapsed = tick() - State.DungeonStartTime
        if elapsed >= Features.DungeonAutoLeave.Timer then
            -- Try to leave dungeon using found remote
            if Remotes.LeaveDungeon then
                pcall(function() Remotes.LeaveDungeon:FireServer() end)
                Notify("Dungeon", "Auto-leaving dungeon...", 3)
                State.InDungeon = false
                DungeonSystem.Active = false
            else
                -- Fallback: Try all dungeon remotes
                for name, remote in pairs(Remotes.DungeonRemotes) do
                    if name:lower():find("leave") or name:lower():find("exit") then
                        pcall(function() remote:FireServer() end)
                        -- Auto-leaving dungeon
                        State.InDungeon = false
                        DungeonSystem.Active = false
                        break
                    end
                end
            end
        end
    end)
    
    -- UPDATED: Dungeon Auto Retry Loop
    LoopManager.Start("DungeonAutoRetry", 10, function()
        if not Features.DungeonAutoRetry.Enabled then return end
        if State.InDungeon then return end
        
        -- If we were in a dungeon and now we're not, re-enter
        if Features.AutoDungeon.Enabled and Features.AutoDungeon.Selected then
            local dungeonName = Features.AutoDungeon.Selected
            local location = DungeonSystem.Locations[dungeonName]
            
            if location then
                -- Auto-retrying dungeon
                SafeTeleport(location)
                task.wait(2)
                
                -- Try to enter dungeon
                if Remotes.EnterDungeon then
                    pcall(function() Remotes.EnterDungeon:FireServer(dungeonName) end)
                end
            end
        end
    end)
    
    -- Auto Collect Loop
    local collectOffset = CFrame.new(0, 0, -3)
    local collectBuffer = {}
    
    LoopManager.Start("AutoCollect", 1, function()
        if not Features.AutoCollect.Enabled and not Features.AutoChests.Enabled then
            return
        end
        
        if not State.StartupDone then return end
        if not State.RootPart or not State.RootPart.Parent then return end
        if not State.Humanoid or State.Humanoid.Health <= 0 then return end
        
        for _, drop in ipairs(EntityCache.List) do
            if drop and drop.Parent then
                local name = drop.Name:lower()
                local shouldCollect = (Features.AutoCollect.Enabled and name:find("drop")) or
                                      (Features.AutoChests.Enabled and name:find("chest"))
                
                if shouldCollect then
                    local root = drop:FindFirstChild("HumanoidRootPart") or drop:FindFirstChildWhichIsA("BasePart")
                    if root and root.Parent then
                        if FarmTeleport(root.CFrame * collectOffset) then
                            if Remotes.MultiEntityHit then
                                collectBuffer[1] = drop
                                pcall(function()
                                    Remotes.MultiEntityHit:FireServer(collectBuffer)
                                end)
                            end
                        end
                        task.wait(0.12)
                    end
                end
            end
        end
    end)
end

