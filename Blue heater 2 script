local function RebuildCharacterParts()
    local parts = {}
    if State.Character then
        for _, descendant in ipairs(State.Character:GetDescendants()) do
            if descendant:IsA("BasePart") then
                table.insert(parts, descendant)
            end
        end
    end
    return parts
end

local function SaveGameDefaults()
    if not State.Humanoid then return end
    
    if State.GameDefaults.UseJumpPower == nil then
        task.wait(0.1)
        State.GameDefaults.UseJumpPower = State.Humanoid.UseJumpPower
        State.GameDefaults.JumpPower = State.Humanoid.JumpPower
        State.GameDefaults.JumpHeight = State.Humanoid.JumpHeight
    end
end

local function RestoreGameDefaults()
    if not State.Humanoid then return end
    
    if State.GameDefaults.UseJumpPower ~= nil then
        State.Humanoid.UseJumpPower = State.GameDefaults.UseJumpPower
        State.Humanoid.JumpPower = State.GameDefaults.JumpPower
        State.Humanoid.JumpHeight = State.GameDefaults.JumpHeight
    end
end

local function ApplyJumpPower()
    if not State.Humanoid then return end
    State.Humanoid.UseJumpPower = true
    State.Humanoid.JumpPower = Features.JumpPower.Value
end

local function FindStaminaObject()
    if not State.Character then return nil end
    
    local values = State.Character:FindFirstChild("Values")
    if values then
        return values:FindFirstChild("Stamina")
    end
    return nil
end

local function RefreshCharacter(character)
    State.Character = character
    State.Humanoid = character:WaitForChild("Humanoid", 8)
    State.RootPart = character:WaitForChild("HumanoidRootPart", 8)
    State.StaminaObj = nil
    
    if not State.Humanoid or not State.RootPart then return end
    
    task.wait(0.05)
    
    -- Reset states
    State.Humanoid.PlatformStand = false
    State.Humanoid.WalkSpeed = Features.WalkSpeed.Enabled and Features.WalkSpeed.Value or 16
    
    -- Save defaults
    SaveGameDefaults()
    
    -- Apply jump settings
    if Features.JumpPower.Enabled then
        ApplyJumpPower()
    else
        RestoreGameDefaults()
    end
    
    -- Reset physics
    State.RootPart.Anchored = false
    State.RootPart.AssemblyLinearVelocity = V3_ZERO
    State.RootPart.RotVelocity = V3_ZERO
    
    -- Find stamina
    State.StaminaObj = FindStaminaObject()
    
    -- Setup stamina listener
    if not State.StaminaObj then
        character.ChildAdded:Connect(function(child)
            if child.Name == "Values" then
                State.StaminaObj = child:WaitForChild("Stamina", 5)
            end
        end)
    end
    
    -- Reset features on respawn
    Features.AutoChests.Enabled = false
    Features.AutoCollect.Enabled = false
    
    if Features.Fly.Enabled then
        ToggleFly(false)
    end
end

local function InitializeCharacter()
    local success = pcall(function()
        local character = LocalPlayer.Character
        if character then
            RefreshCharacter(character)
        end
        
        LocalPlayer.CharacterAdded:Connect(function(newChar)
            task.wait(0.1)
            RefreshCharacter(newChar)
        end)
    end)
end

