local function InitializeRemotes()
    local success = pcall(function()
        Remotes.PlayerEvents = ReplicatedStorage:WaitForChild("PlayerEvents", 10)
        if Remotes.PlayerEvents then
            Remotes.MultiEntityHit = Remotes.PlayerEvents:WaitForChild("MultiEntityHit", 10)
            
            Remotes.PlayerEvents.ChildAdded:Connect(function(child)
                if child.Name == "MultiEntityHit" then
                    Remotes.MultiEntityHit = child
                end
            end)
        end
    end)
    
    if not success then
        warn("[Blue Heater 2] Failed to initialize PlayerEvents")
    end
    
    -- Find dungeon remotes
    local success2 = pcall(function()
        for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                local name = remote.Name:lower()
                if name:find("dungeon") or name:find("raid") or name:find("enter") or name:find("leave") or name:find("exit") then
                    Remotes.DungeonRemotes[remote.Name] = remote
                    if name:find("enter") then
                        Remotes.EnterDungeon = remote
                    elseif name:find("leave") or name:find("exit") then
                        Remotes.LeaveDungeon = remote
                    end
                end
            end
        end
    end)
    
    local success3 = pcall(function()
        EntityCache.SpawnedEntities = Workspace:WaitForChild("SpawnedEntities", 10)
    end)
    
    if not success3 then
        warn("[Blue Heater 2] SpawnedEntities not found in Workspace")
    end
end

local function RebuildEntityCache()
    EntityCache.List = {}
    EntityCache.Set = {}
    
    if not EntityCache.SpawnedEntities then 
        local success = pcall(function()
            EntityCache.SpawnedEntities = Workspace:WaitForChild("SpawnedEntities", 5)
        end)
        if not success then return end
    end
    
    for _, entity in ipairs(EntityCache.SpawnedEntities:GetChildren()) do
        if entity:IsA("Model") then
            table.insert(EntityCache.List, entity)
            EntityCache.Set[entity] = true
        end
    end
end

local function SetupEntityCache()
    -- Cleanup existing connections
    for _, conn in pairs(EntityCache.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    EntityCache.Connections = {}
    
    if not EntityCache.SpawnedEntities then 
        local success = pcall(function()
            EntityCache.SpawnedEntities = Workspace:WaitForChild("SpawnedEntities", 5)
        end)
        if not success then return end
    end
    
    RebuildEntityCache()
    
    local success1 = pcall(function()
        local conn1 = EntityCache.SpawnedEntities.ChildAdded:Connect(function(entity)
            if entity:IsA("Model") and not EntityCache.Set[entity] then
                table.insert(EntityCache.List, entity)
                EntityCache.Set[entity] = true
                
                -- Apply ESP if enabled
                if Features.MobESP.Enabled and entity:FindFirstChild("HumanoidRootPart") then
                    local color = IsBoss(entity.Name) and ESPSystem.Colors.Boss or ESPSystem.Colors.Mob
                    CreateESP(entity, color)
                end
            end
        end)
        table.insert(EntityCache.Connections, conn1)
    end)
    
    local success2 = pcall(function()
        local conn2 = EntityCache.SpawnedEntities.ChildRemoved:Connect(function(entity)
            if EntityCache.Set[entity] then
                EntityCache.Set[entity] = nil
                for i = 1, #EntityCache.List do
                    if EntityCache.List[i] == entity then
                        EntityCache.List[i] = EntityCache.List[#EntityCache.List]
                        EntityCache.List[#EntityCache.List] = nil
                        break
                    end
                end
                -- Remove ESP
                RemoveESP(entity)
            end
        end)
        table.insert(EntityCache.Connections, conn2)
    end)
end

