-- ═══════════════════════════════════════════════════════════════════════════════

local MobDropdown = nil
local LastMobList = {}

local function GetUniqueMobNames()
    if not EntityCache.SpawnedEntities or #EntityCache.List == 0 then
        return {"(No mobs found)"}
    end
    
    local seen = {}
    local names = {}
    
    for _, entity in ipairs(EntityCache.List) do
        if entity and entity ~= State.Character then
            local name = entity.Name
            if not seen[name] then
                seen[name] = true
                table.insert(names, name)
            end
        end
    end
    
    table.sort(names)
    return #names > 0 and names or {"(No mobs found)"}
end

local function ListsEqual(a, b)
    if #a ~= #b then return false end
    for i = 1, #a do
        if a[i] ~= b[i] then return false end
    end
    return true
end

local function RefreshMobDropdown()
    if not MobDropdown then return end
    
    local newList = GetUniqueMobNames()
    if ListsEqual(newList, LastMobList) then return end
    
    LastMobList = newList
    pcall(function() MobDropdown:SetValues(newList) end)
    
    local valid = false
    for _, name in ipairs(newList) do
        if name == Features.AutoModCustom.Name then
            valid = true
            break
        end
    end
    
    if not valid then
        Features.AutoModCustom.Name = newList[1] or ""
        pcall(function() MobDropdown:SetValue(Features.AutoModCustom.Name) end)
    end
end

