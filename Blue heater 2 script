function CreateESP(target, color)
    if ESPSystem.Highlights[target] or not target or not target.Parent then
        return
    end
    
    local success, highlight = pcall(function()
        local hl = Instance.new("Highlight")
        hl.FillColor = color
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.FillTransparency = 0.5
        hl.OutlineTransparency = 0
        hl.Parent = target
        return hl
    end)
    
    if not success or not highlight then return end
    
    ESPSystem.Highlights[target] = highlight
    
    local success2 = pcall(function()
        ESPSystem.AncestryConnections[target] = target.AncestryChanged:Connect(function()
            if not target.Parent then
                if ESPSystem.Highlights[target] then
                    pcall(function() ESPSystem.Highlights[target]:Destroy() end)
                    ESPSystem.Highlights[target] = nil
                end
                if ESPSystem.AncestryConnections[target] then
                    ESPSystem.AncestryConnections[target]:Disconnect()
                    ESPSystem.AncestryConnections[target] = nil
                end
            end
        end)
    end)
end

function RemoveESP(target)
    if ESPSystem.Highlights[target] then
        pcall(function() ESPSystem.Highlights[target]:Destroy() end)
        ESPSystem.Highlights[target] = nil
    end
    if ESPSystem.AncestryConnections[target] then
        ESPSystem.AncestryConnections[target]:Disconnect()
        ESPSystem.AncestryConnections[target] = nil
    end
end

local function ClearAllESP()
    for target, _ in pairs(ESPSystem.Highlights) do
        RemoveESP(target)
    end
end

local function CleanupESPConnections()
    for _, conn in ipairs(ESPSystem.ActiveConnections) do
        pcall(function() conn:Disconnect() end)
    end
    ESPSystem.ActiveConnections = {}
end

local function ToggleMobESP(enabled)
    Features.MobESP.Enabled = enabled
    CleanupESPConnections()
    
    if enabled then
        if EntityCache.SpawnedEntities then
            -- Apply ESP to existing mobs
            for _, entity in ipairs(EntityCache.SpawnedEntities:GetChildren()) do
                if entity:IsA("Model") and entity:FindFirstChild("HumanoidRootPart") then
                    local color = IsBoss(entity.Name) and ESPSystem.Colors.Boss or ESPSystem.Colors.Mob
                    CreateESP(entity, color)
                end
            end
            
            -- Listen for new mobs
            local success1 = pcall(function()
                local conn1 = EntityCache.SpawnedEntities.ChildAdded:Connect(function(entity)
                    if not Features.MobESP.Enabled then return end
                    task.wait(0.1)
                    if entity and entity.Parent and entity:IsA("Model") and entity:FindFirstChild("HumanoidRootPart") then
                        local color = IsBoss(entity.Name) and ESPSystem.Colors.Boss or ESPSystem.Colors.Mob
                        CreateESP(entity, color)
                    end
                end)
                table.insert(ESPSystem.ActiveConnections, conn1)
            end)
            
            local success2 = pcall(function()
                local conn2 = EntityCache.SpawnedEntities.ChildRemoved:Connect(RemoveESP)
                table.insert(ESPSystem.ActiveConnections, conn2)
            end)
        end
        
        -- Mob ESP enabled
    else
        ClearAllESP()
        -- Mob ESP disabled
    end
end

local function TogglePlayerESP(enabled)
    Features.PlayerESP.Enabled = enabled
    
    if enabled then
        -- Apply ESP to existing players
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                CreateESP(player.Character, ESPSystem.Colors.Player)
            end
        end
        
        -- Listen for new players
        local function OnCharacterAdded(character)
            task.wait(0.1)
            if Features.PlayerESP.Enabled and character and character.Parent then
                CreateESP(character, ESPSystem.Colors.Player)
            end
        end
        
        local success = pcall(function()
            local conn1 = Players.PlayerAdded:Connect(function(player)
                table.insert(ESPSystem.ActiveConnections, player.CharacterAdded:Connect(OnCharacterAdded))
            end)
            table.insert(ESPSystem.ActiveConnections, conn1)
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    table.insert(ESPSystem.ActiveConnections, player.CharacterAdded:Connect(OnCharacterAdded))
                end
            end
        end)
        
        -- Player ESP enabled
    else
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then
                RemoveESP(player.Character)
            end
        end
        CleanupESPConnections()
        -- Player ESP disabled
    end
end

