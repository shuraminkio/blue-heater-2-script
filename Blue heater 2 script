--   LOOP MANAGEMENT
-- ═══════════════════════════════════════════════════════════════════════════════

function LoopManager.Start(name, interval, callback)
    LoopManager.Stop(name)
    
    LoopManager.Active[name] = task.spawn(function()
        while true do
            local success, err = pcall(callback)
            if not success then
                warn("[" .. name .. " Error]: " .. tostring(err))
            end
            task.wait(interval)
        end
    end)
end

function LoopManager.Stop(name)
    if LoopManager.Active[name] then
        task.cancel(LoopManager.Active[name])
        LoopManager.Active[name] = nil
    end
end

function LoopManager.StopAll()
    for name, _ in pairs(LoopManager.Active) do
        LoopManager.Stop(name)
    end
end

