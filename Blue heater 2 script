--   DUNGEON DETECTION SYSTEM
-- ═══════════════════════════════════════════════════════════════════════════════

local function DetectDungeonEntry()
    -- Check if we're in a dungeon by looking at:
    -- 1. Workspace structure changes
    -- 2. Specific dungeon objects
    -- 3. Mob types in the area
    
    local inDungeon = false
    local dungeonName = nil
    
    -- Check for dungeon-specific objects
    pcall(function()
        -- Look for dungeon portal/exit objects
        for _, obj in ipairs(Workspace:GetDescendants()) do
            local name = obj.Name:lower()
            if name:find("dungeon") or name:find("exit") or name:find("portal") then
                if obj:IsA("BasePart") or obj:IsA("Model") then
                    inDungeon = true
                end
            end
        end
        
        -- Check mob composition
        local dungeonMobCount = 0
        local totalMobCount = 0
        
        for _, entity in ipairs(EntityCache.List) do
            if entity and entity.Parent then
                totalMobCount = totalMobCount + 1
                if IsDungeonMob(entity.Name) then
                    dungeonMobCount = dungeonMobCount + 1
                end
            end
        end
        
        -- If majority of mobs are dungeon mobs, we're likely in a dungeon
        if totalMobCount > 0 and (dungeonMobCount / totalMobCount) > 0.7 then
            inDungeon = true
        end
    end)
    
    return inDungeon
end

local function UpdateDungeonStatus()
    local wasInDungeon = State.InDungeon
    State.InDungeon = DetectDungeonEntry()
    
    if State.InDungeon and not wasInDungeon then
        State.DungeonStartTime = tick()
        DungeonSystem.Active = true
        -- Entered dungeon
    elseif not State.InDungeon and wasInDungeon then
        DungeonSystem.Active = false
        State.DungeonStartTime = 0
        -- Left dungeon
    end
end

