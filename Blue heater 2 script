--   INITIALIZATION
-- ═══════════════════════════════════════════════════════════════════════════════

local function Initialize()
    -- Initialize remotes and cache
    InitializeRemotes()
    SetupEntityCache()
    
    -- Setup workspace listener
    local success = pcall(function()
        Workspace.ChildAdded:Connect(function(child)
            if child.Name == "SpawnedEntities" then
                EntityCache.SpawnedEntities = child
                task.wait(0.1)
                SetupEntityCache()
            end
        end)
    end)
    
    -- Initialize character
    InitializeCharacter()
    
    -- Start core loops
    InitializeCoreLoops()
    
    -- Load config
    SaveManager:LoadAutoloadConfig()
    
    -- Reset conflicting features
    task.wait(0.15)
    Features.JumpPower.Enabled = false
    Features.InfiniteJump.Enabled = false
    CleanupInfiniteJump()
    RestoreGameDefaults()
    
    task.wait(0.05)
    pcall(function() Tabs.Dashboard:Select() end)
    
    -- Script loaded silently
    -- print("[Blue Heater 2] Made by Mink - Loaded Successfully!")
    -- print("[Blue Heater 2] Only is only supposed to be used in Blue Heater 2. Use in other games may cause issues.")
end

-- Start the script
Initialize() 
