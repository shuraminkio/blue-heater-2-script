        NoclipSystem.DescendantConnection:Disconnect()
    end
    
    NoclipSystem.Parts = RebuildCharacterParts()
    
    local success = pcall(function()
        NoclipSystem.DescendantConnection = State.Character.DescendantAdded:Connect(function(descendant)
            if descendant:IsA("BasePart") then
                table.insert(NoclipSystem.Parts, descendant)
            end
        end)
    end)
    
    NoclipSystem.Connection = RunService.Stepped:Connect(function()
        if not Features.Noclip.Enabled then return end
        for _, part in ipairs(NoclipSystem.Parts) do
            if part and part.Parent and part.CanCollide then
                part.CanCollide = false
            end
        end
    end)
end

local function DisableNoclip()
