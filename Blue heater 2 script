local function CleanupFlight()
    if FlightSystem.BodyVelocity and FlightSystem.BodyVelocity.Parent then
        FlightSystem.BodyVelocity:Destroy()
    end
    if FlightSystem.BodyGyro and FlightSystem.BodyGyro.Parent then
        FlightSystem.BodyGyro:Destroy()
    end
    FlightSystem.BodyVelocity = nil
    FlightSystem.BodyGyro = nil
end

function ToggleFly(enabled)
    Features.Fly.Enabled = enabled
    
    if enabled then
        if not State.RootPart then
            Notify("Error", "Character not found!", 3)
            Features.Fly.Enabled = false
            return
        end
        
        if FlightSystem.Connection then
            FlightSystem.Connection:Disconnect()
        end
        
        CleanupFlight()
        
        if State.Humanoid then
            State.Humanoid.PlatformStand = true
        end
        
        -- Create flight physics
        local success = pcall(function()
            FlightSystem.BodyVelocity = Instance.new("BodyVelocity")
            FlightSystem.BodyVelocity.Velocity = V3_ZERO
            FlightSystem.BodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            FlightSystem.BodyVelocity.P = 1e4
            FlightSystem.BodyVelocity.Parent = State.RootPart
            
            FlightSystem.BodyGyro = Instance.new("BodyGyro")
            FlightSystem.BodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
            FlightSystem.BodyGyro.P = 1e4
            FlightSystem.BodyGyro.D = 100
            FlightSystem.BodyGyro.CFrame = State.RootPart.CFrame
            FlightSystem.BodyGyro.Parent = State.RootPart
        end)
        
        if not success then
            Notify("Error", "Failed to create flight physics", 3)
            Features.Fly.Enabled = false
            return
        end
        
        -- Flight control loop
        FlightSystem.Connection = RunService.RenderStepped:Connect(function()
            if not Features.Fly.Enabled or not State.RootPart or not FlightSystem.BodyVelocity then
                return
            end
            
            local cameraCF = Camera.CFrame
            local direction = V3_ZERO
            
            if UserInputService:IsKeyDown(FlightSystem.Keys.W) then
                direction = direction + cameraCF.LookVector
            end
            if UserInputService:IsKeyDown(FlightSystem.Keys.S) then
                direction = direction - cameraCF.LookVector
            end
            if UserInputService:IsKeyDown(FlightSystem.Keys.A) then
                direction = direction - cameraCF.RightVector
            end
            if UserInputService:IsKeyDown(FlightSystem.Keys.D) then
                direction = direction + cameraCF.RightVector
            end
            if UserInputService:IsKeyDown(FlightSystem.Keys.Space) then
                direction = direction + V3_UP
            end
            if UserInputService:IsKeyDown(FlightSystem.Keys.Shift) then
                direction = direction + V3_DOWN
            end
            
            FlightSystem.BodyVelocity.Velocity = direction.Magnitude > 0 
                and direction.Unit * Features.Fly.Speed 
                or V3_ZERO
            
            FlightSystem.BodyGyro.CFrame = CFrame.new(V3_ZERO, cameraCF.LookVector)
        end)
        
        -- Flight enabled
    else
        if FlightSystem.Connection then
            FlightSystem.Connection:Disconnect()
            FlightSystem.Connection = nil
        end
        
        CleanupFlight()
        
        if State.Humanoid then
            State.Humanoid.PlatformStand = false
        end
        
        if State.RootPart then
            State.RootPart.AssemblyLinearVelocity = V3_ZERO
        end
        
        -- Flight disabled
    end
end

